{% schema %}
{
  "name": "領収書宛名入力",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "ラベル",
      "default": "領収書の宛名（任意）"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "プレースホルダー",
      "default": "例: 株式会社サンプル"
    },
    {
      "type": "text",
      "id": "hint",
      "label": "補足説明",
      "default": "記入された場合、領収書 PDF の宛名に反映されます (空欄なら注文者名)"
    },
    {
      "type": "color",
      "id": "background",
      "label": "背景色",
      "default": "#f6f6f7"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上余白",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下余白",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16,
      "unit": "px"
    }
  ]
}
{% endschema %}

<div
  class="receipt-recipient-block"
  style="margin: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px; padding: 14px 16px; background: {{ block.settings.background }}; border-radius: 6px;"
  {{ block.shopify_attributes }}
>
  <label
    for="cart-receipt-recipient"
    style="display:block;margin-bottom:6px;font-weight:600;font-size:14px;"
  >
    {{ block.settings.label }}
  </label>
  <input
    type="text"
    id="cart-receipt-recipient"
    name="attributes[receipt_recipient]"
    value="{{ cart.attributes.receipt_recipient | escape }}"
    placeholder="{{ block.settings.placeholder }}"
    form="cart"
    style="width:100%;padding:8px 10px;border:1px solid #c9cccf;border-radius:4px;font-size:14px;box-sizing:border-box;font-family:inherit;"
  >
  {% if block.settings.hint != blank %}
    <p style="font-size:12px;color:#6d7175;margin:6px 0 0;line-height:1.5;">
      {{ block.settings.hint }}
    </p>
  {% endif %}
</div>
