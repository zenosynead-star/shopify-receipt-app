{% schema %}
{
  "name": "領収書宛名入力 (カート)",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "ラベル",
      "default": "領収書の宛名（任意）"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "プレースホルダー",
      "default": "例: 株式会社サンプル"
    },
    {
      "type": "text",
      "id": "hint",
      "label": "補足説明",
      "default": "記入された場合、領収書 PDF の宛名に反映されます (空欄なら注文者名)"
    }
  ]
}
{% endschema %}

<script>
(function() {
  var INITIAL_VALUE = {{ cart.attributes.receipt_recipient | json }};
  var LABEL = {{ block.settings.label | json }};
  var PLACEHOLDER = {{ block.settings.placeholder | json }};
  var HINT = {{ block.settings.hint | json }};
  var INPUT_ID = 'cart-receipt-recipient';

  function buildWrap() {
    var wrap = document.createElement('div');
    wrap.style.cssText = 'margin:16px 0;padding:14px 16px;background:#f6f6f7;border-radius:6px;';

    var label = document.createElement('label');
    label.setAttribute('for', INPUT_ID);
    label.style.cssText = 'display:block;margin-bottom:6px;font-weight:600;font-size:14px;';
    label.textContent = LABEL;

    var input = document.createElement('input');
    input.type = 'text';
    input.id = INPUT_ID;
    input.name = 'attributes[receipt_recipient]';
    input.value = INITIAL_VALUE || '';
    input.placeholder = PLACEHOLDER;
    input.style.cssText = 'width:100%;padding:8px 10px;border:1px solid #c9cccf;border-radius:4px;font-size:14px;box-sizing:border-box;font-family:inherit;';

    // 入力値を即座に cart attributes に保存 (Ajax)
    input.addEventListener('change', function() {
      var fd = new FormData();
      fd.append('attributes[receipt_recipient]', input.value);
      fetch('/cart/update.js', { method: 'POST', body: fd }).catch(function() {});
    });

    var hint = document.createElement('p');
    hint.style.cssText = 'font-size:12px;color:#6d7175;margin:6px 0 0;line-height:1.5;';
    hint.textContent = HINT;

    wrap.appendChild(label);
    wrap.appendChild(input);
    wrap.appendChild(hint);
    return wrap;
  }

  function inject() {
    if (!location.pathname.match(/\/cart/)) return;
    if (document.getElementById(INPUT_ID)) return; // 重複挿入防止

    // チェックアウトボタンを最優先で探す (どの Dawn でも存在)
    var checkoutBtn = document.querySelector(
      '[name="checkout"], button[name="checkout"], a[href*="/checkout"], .cart__checkout-button, #checkout, [data-checkout]',
    );
    if (!checkoutBtn) return;

    var wrap = buildWrap();
    var parent = checkoutBtn.parentNode;
    parent.insertBefore(wrap, checkoutBtn);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', inject);
  } else {
    inject();
  }
  // Cart drawer や Ajax 更新でも追従
  [200, 800, 2000, 4000].forEach(function(t) { setTimeout(inject, t); });

  // DOM 変更を監視 (cart drawer の開閉、Ajax 更新)
  if (typeof MutationObserver !== 'undefined') {
    var observer = new MutationObserver(function() { inject(); });
    observer.observe(document.body, { childList: true, subtree: true });
  }
})();
</script>
